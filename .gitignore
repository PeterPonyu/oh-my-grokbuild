# Dependencies / build
node_modules/
*.log

# Source-brand config dir at repo root: not used by this Grok plugin.
# The legitimate Claude-compat manifest lives under .claude-plugin/ (tracked);
# a bare root .claude/ is a stray artifact and must never be committed.
/.claude/

# OS / editor noise
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~

# OMGB runtime state (per-machine, never source)
.omgb/
.omc/
.grok/
!.grok/omgb/runs/.keep

# Run artifacts (export handoffs)
omgb-handoff-*.md

# Local scratch / temp
scratch/
tmp/
.tmp/
*.tmp
*.bak

# Python (if anyone drops a venv next to the plugin)
__pycache__/
*.pyc
.venv/
venv/
